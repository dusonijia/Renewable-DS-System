# 数据库配置
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ai_intelligence_platform
POSTGRES_USER=admin
POSTGRES_PASSWORD=your_password

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password

# Neo4j配置（知识图谱）
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password

# Elasticsearch配置
ELASTICSEARCH_HOST=localhost
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_INDEX=intelligence_data

# 大模型API配置
OPENAI_API_KEY=your_openai_key
OPENAI_BASE_URL=https://api.openai.com/v1
AZURE_OPENAI_ENDPOINT=your_azure_endpoint
AZURE_OPENAI_KEY=your_azure_key

# 数据源API配置
DERWENT_API_KEY=your_derwent_key
ZHIHUIYA_API_KEY=your_zhihuiya_key
BLOOMBERG_API_KEY=your_bloomberg_key

# 应用配置
APP_NAME=AI Intelligence Platform
APP_VERSION=1.0.0
DEBUG=False
SECRET_KEY=your_secret_key
ACCESS_TOKEN_EXPIRE_MINUTES=30

# 爬虫配置
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36
REQUEST_DELAY=1
CONCURRENT_REQUESTS=16

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# 安全配置
ENCRYPTION_KEY=your_encryption_key
JWT_SECRET_KEY=your_jwt_secret

# 监控配置
PROMETHEUS_PORT=8000
ENABLE_METRICS=True